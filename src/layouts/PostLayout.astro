---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  author?: string;
  date: Date;
  image?: string;
  image_alt?: string;
  tags?: string[];
}

const { title, description, author, date, image, image_alt, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={title}
  seo={{
    page_description: description,
    featured_image: image,
    open_graph_type: 'article',
  }}
>
  <article class="py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      {image && (
        <img
          src={image}
          alt={image_alt || title}
          class="mb-8 w-full rounded-[var(--radius-theme)] shadow-lg"
          loading="eager"
        />
      )}

      <header class="mb-12">
        {tags.length > 0 && (
          <div class="mb-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        {description && (
          <p class="mt-4 text-lg text-text-muted">{description}</p>
        )}

        <div class="mt-6 flex items-center gap-4 text-sm text-text-muted">
          {author && <span>By <strong class="text-text-base">{author}</strong></span>}
          <span>&middot;</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </div>
      </header>

      <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-secondary prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-[var(--radius-theme)]">
        <slot />
      </div>
    </div>
  </article>
</Layout>
