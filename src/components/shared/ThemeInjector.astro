---
import themeData from '../../../data/theme.json';

const radiusMap: Record<string, string> = {
  none: '0',
  small: '0.25rem',
  medium: '0.5rem',
  large: '1rem',
  full: '9999px',
};

const fontMap: Record<string, string> = {
  Inter: "'Inter', sans-serif",
  'Space Grotesk': "'Space Grotesk', sans-serif",
  'DM Sans': "'DM Sans', sans-serif",
  Sora: "'Sora', sans-serif",
};

const primaryColor = themeData.primary_color || '#4F46E5';
const secondaryColor = themeData.secondary_color || '#0F172A';
const accentColor = themeData.accent_color || '#F59E0B';
const fontHeading = fontMap[themeData.font_heading] || fontMap['Inter'];
const fontBody = fontMap[themeData.font_body] || fontMap['Inter'];
const radius = radiusMap[themeData.border_radius] || radiusMap['medium'];

function hexToHsl(hex: string) {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  const l = (max + min) / 2;
  if (max === min) return { h: 0, s: 0, l };
  const d = max - min;
  const s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
  let h = 0;
  if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
  else if (max === g) h = ((b - r) / d + 2) / 6;
  else h = ((r - g) / d + 4) / 6;
  return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
}

const primary = hexToHsl(primaryColor);
const primaryLightL = Math.min(primary.l + 15, 90);
const primaryDarkL = Math.max(primary.l - 15, 10);
---

<style is:inline set:html={`
  :root {
    --theme-primary: ${primaryColor};
    --theme-primary-light: hsl(${primary.h}, ${primary.s}%, ${primaryLightL}%);
    --theme-primary-dark: hsl(${primary.h}, ${primary.s}%, ${primaryDarkL}%);
    --theme-secondary: ${secondaryColor};
    --theme-accent: ${accentColor};
    --theme-font-heading: ${fontHeading};
    --theme-font-body: ${fontBody};
    --theme-radius: ${radius};
  }
`} />
