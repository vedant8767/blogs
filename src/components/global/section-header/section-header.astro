---
import SectionWrapper from '../../shared/SectionWrapper.astro';

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  alignment?: 'left' | 'center';
}

const {
  _cms_bind,
  heading = 'Section Title',
  subheading = 'A brief description of this section.',
  alignment = 'center',
} = Astro.props;
---

<SectionWrapper>
  <div class:list={['mx-auto max-w-3xl', alignment === 'center' && 'text-center']}>
    <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl">{heading}</h2>
    {subheading && <p data-editable="text" data-prop="subheading" class="mt-4 text-lg text-text-muted">{subheading}</p>}
  </div>
</SectionWrapper>
