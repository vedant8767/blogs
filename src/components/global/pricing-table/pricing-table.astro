---
import SectionWrapper from '../../shared/SectionWrapper.astro';
import Button from '../../shared/Button.astro';

interface PricingFeature {
  text: string;
  included: boolean;
}

interface PricingTier {
  name: string;
  monthly_price: string;
  annual_price?: string;
  description?: string;
  features: PricingFeature[];
  button: { text: string; link: string };
  highlighted?: boolean;
}

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  show_annual_toggle?: boolean;
  tiers?: PricingTier[];
}

const {
  _cms_bind,
  heading = 'Simple, Transparent Pricing',
  subheading = 'Choose the plan that works for you.',
  show_annual_toggle = true,
  tiers = [
    {
      name: 'Starter', monthly_price: '$9', annual_price: '$7', description: 'For individuals getting started.',
      features: [{ text: '1 Project', included: true }, { text: '5GB Storage', included: true }, { text: 'Priority Support', included: false }],
      button: { text: 'Get Started', link: '#' }, highlighted: false,
    },
    {
      name: 'Pro', monthly_price: '$29', annual_price: '$24', description: 'For growing teams.',
      features: [{ text: 'Unlimited Projects', included: true }, { text: '50GB Storage', included: true }, { text: 'Priority Support', included: true }],
      button: { text: 'Get Started', link: '#' }, highlighted: true,
    },
    {
      name: 'Enterprise', monthly_price: '$99', annual_price: '$79', description: 'For large organizations.',
      features: [{ text: 'Unlimited Projects', included: true }, { text: 'Unlimited Storage', included: true }, { text: '24/7 Support', included: true }],
      button: { text: 'Contact Sales', link: '#' }, highlighted: false,
    },
  ],
} = Astro.props;
---

<SectionWrapper>
  <div class="mx-auto max-w-3xl text-center">
    <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl">{heading}</h2>
    <p data-editable="text" data-prop="subheading" class="mt-4 text-lg text-text-muted">{subheading}</p>
    {show_annual_toggle && (
      <div class="mt-8 flex items-center justify-center gap-3">
        <span class="text-sm text-text-muted" data-pricing-label="monthly">Monthly</span>
        <button id="pricing-toggle" class="relative h-7 w-12 rounded-full bg-primary/20 transition-colors" aria-label="Toggle annual pricing">
          <span class="absolute left-1 top-1 h-5 w-5 rounded-full bg-primary transition-transform" id="pricing-toggle-dot"></span>
        </button>
        <span class="text-sm text-text-muted" data-pricing-label="annual">Annual</span>
      </div>
    )}
  </div>
  <div class="mt-12 grid gap-8 lg:grid-cols-3">
    {tiers.map((tier, ti) => (
      <div class:list={[
        'rounded-[var(--radius-theme)] border p-8 flex flex-col',
        tier.highlighted ? 'border-primary shadow-lg ring-2 ring-primary relative' : 'border-border',
      ]}>
        {tier.highlighted && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-semibold text-white">Most Popular</span>
        )}
        <h3 data-editable="text" data-prop={`tiers.${ti}.name`} class="text-xl font-bold text-secondary">{tier.name}</h3>
        {tier.description && <p data-editable="text" data-prop={`tiers.${ti}.description`} class="mt-2 text-sm text-text-muted">{tier.description}</p>}
        <div class="mt-6">
          <span class="text-4xl font-bold text-secondary" data-monthly-price={tier.monthly_price} data-annual-price={tier.annual_price || tier.monthly_price}>{tier.monthly_price}</span>
          <span class="text-text-muted">/mo</span>
        </div>
        <ul class="mt-8 flex-1 space-y-3">
          {tier.features.map((feature) => (
            <li class="flex items-center gap-3">
              {feature.included ? (
                <svg class="h-5 w-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              ) : (
                <svg class="h-5 w-5 text-gray-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              )}
              <span class:list={[feature.included ? 'text-text-base' : 'text-text-muted']}>{feature.text}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <Button text={tier.button.text} link={tier.button.link} variant={tier.highlighted ? 'primary' : 'outline'} class="w-full" />
        </div>
      </div>
    ))}
  </div>
</SectionWrapper>

<script>
  const toggle = document.getElementById('pricing-toggle');
  const dot = document.getElementById('pricing-toggle-dot');
  let annual = false;
  toggle?.addEventListener('click', () => {
    annual = !annual;
    dot?.classList.toggle('translate-x-5', annual);
    document.querySelectorAll('[data-monthly-price]').forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = annual
        ? htmlEl.dataset.annualPrice || htmlEl.dataset.monthlyPrice || ''
        : htmlEl.dataset.monthlyPrice || '';
    });
  });
</script>
