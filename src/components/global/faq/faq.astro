---
import SectionWrapper from '../../shared/SectionWrapper.astro';

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  items?: FaqItem[];
}

const {
  _cms_bind,
  heading = 'Frequently Asked Questions',
  subheading = 'Find answers to common questions.',
  items = [
    { question: 'How do I get started?', answer: 'Sign up for a free account and follow our quick start guide.' },
    { question: 'Can I cancel anytime?', answer: 'Yes, you can cancel your subscription at any time with no penalties.' },
    { question: 'Is there a free trial?', answer: 'We offer a 14-day free trial on all plans.' },
  ],
} = Astro.props;
---

<SectionWrapper background="light">
  <div class="mx-auto max-w-3xl">
    <div class="text-center">
      <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl">{heading}</h2>
      <p data-editable="text" data-prop="subheading" class="mt-4 text-lg text-text-muted">{subheading}</p>
    </div>
    <div class="mt-12 space-y-4">
      {items.map((item, i) => (
        <details class="group rounded-[var(--radius-theme)] border border-border bg-surface" open={i === 0}>
          <summary class="flex cursor-pointer items-center justify-between p-6 font-medium text-secondary">
            <span data-editable="text" data-prop={`items.${i}.question`}>{item.question}</span>
            <svg class="h-5 w-5 shrink-0 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div data-editable="text" data-prop={`items.${i}.answer`} class="px-6 pb-6 text-text-muted leading-relaxed">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</SectionWrapper>
