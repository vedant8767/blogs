---
import SectionWrapper from '../../shared/SectionWrapper.astro';

interface Lesson {
  title: string;
  duration?: string;
}

interface Module {
  title: string;
  description?: string;
  lessons: Lesson[];
}

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  modules?: Module[];
}

const {
  _cms_bind,
  heading = 'Course Curriculum',
  subheading = 'What you will learn in this course.',
  modules = [
    { title: 'Module 1: Getting Started', description: 'Foundation concepts and setup.', lessons: [{ title: 'Introduction', duration: '5 min' }, { title: 'Setting Up Your Environment', duration: '10 min' }] },
    { title: 'Module 2: Core Concepts', description: 'Deep dive into the fundamentals.', lessons: [{ title: 'Key Principles', duration: '15 min' }, { title: 'Hands-on Practice', duration: '20 min' }] },
  ],
} = Astro.props;
---

<SectionWrapper>
  <div class="mx-auto max-w-3xl text-center">
    <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl">{heading}</h2>
    <p data-editable="text" data-prop="subheading" class="mt-4 text-lg text-text-muted">{subheading}</p>
  </div>
  <div class="mx-auto mt-12 max-w-3xl space-y-6">
    {modules.map((mod, mi) => (
      <details class="group rounded-[var(--radius-theme)] border border-border bg-surface" open={mi === 0}>
        <summary class="flex cursor-pointer items-center justify-between p-6">
          <div>
            <h3 data-editable="text" data-prop={`modules.${mi}.title`} class="font-semibold text-secondary">{mod.title}</h3>
            {mod.description && <p data-editable="text" data-prop={`modules.${mi}.description`} class="mt-1 text-sm text-text-muted">{mod.description}</p>}
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-text-muted">{mod.lessons.length} lessons</span>
            <svg class="h-5 w-5 shrink-0 text-text-muted transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </summary>
        <div class="border-t border-border">
          {mod.lessons.map((lesson, li) => (
            <div class="flex items-center justify-between px-6 py-3 hover:bg-surface-alt transition-colors">
              <div class="flex items-center gap-3">
                <svg class="h-4 w-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span data-editable="text" data-prop={`modules.${mi}.lessons.${li}.title`} class="text-sm text-text-base">{lesson.title}</span>
              </div>
              {lesson.duration && <span class="text-xs text-text-muted">{lesson.duration}</span>}
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>
</SectionWrapper>
