---
import SectionWrapper from '../../shared/SectionWrapper.astro';

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  button?: { text: string; link: string };
}

const {
  _cms_bind,
  heading = 'Ready to Get Started?',
  subheading = 'Join thousands of teams already using our platform.',
  button = { text: 'Start Free Trial', link: '#' },
} = Astro.props;
---

<SectionWrapper background="primary">
  <div class="mx-auto max-w-3xl text-center">
    <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight sm:text-4xl">
      {heading}
    </h2>
    <p data-editable="text" data-prop="subheading" class="mt-4 text-lg opacity-90">
      {subheading}
    </p>
    {button && (
      <div class="mt-8">
        <a
          href={button.link}
          class="inline-flex items-center justify-center rounded-[var(--radius-theme)] bg-white px-8 py-4 text-lg font-medium text-primary hover:bg-gray-100 transition-colors"
        >
          {button.text}
        </a>
      </div>
    )}
  </div>
</SectionWrapper>
