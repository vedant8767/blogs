---
import SectionWrapper from '../../shared/SectionWrapper.astro';

interface DocCategory {
  title: string;
  icon?: string;
  description: string;
  link: string;
}

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  categories?: DocCategory[];
}

const {
  _cms_bind,
  heading = 'Documentation',
  subheading = 'Find the information you need.',
  categories = [
    { title: 'Getting Started', icon: '🚀', description: 'Quick start guide and setup instructions.', link: '#' },
    { title: 'API Reference', icon: '📚', description: 'Comprehensive API documentation.', link: '#' },
    { title: 'Tutorials', icon: '🎓', description: 'Step-by-step guides and walkthroughs.', link: '#' },
    { title: 'Examples', icon: '💡', description: 'Sample projects and code examples.', link: '#' },
    { title: 'Configuration', icon: '⚙️', description: 'Configure and customize your setup.', link: '#' },
    { title: 'FAQ', icon: '❓', description: 'Common questions and answers.', link: '#' },
  ],
} = Astro.props;
---

<SectionWrapper>
  <div class="mx-auto max-w-3xl text-center">
    <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl">{heading}</h2>
    <p data-editable="text" data-prop="subheading" class="mt-4 text-lg text-text-muted">{subheading}</p>
  </div>
  <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {categories.map((cat, i) => (
      <a href={cat.link} class="group rounded-[var(--radius-theme)] border border-border bg-surface p-6 hover:border-primary hover:shadow-md transition-all">
        {cat.icon && <span class="text-2xl">{cat.icon}</span>}
        <h3 data-editable="text" data-prop={`categories.${i}.title`} class="mt-3 font-semibold text-secondary group-hover:text-primary transition-colors">{cat.title}</h3>
        <p data-editable="text" data-prop={`categories.${i}.description`} class="mt-2 text-sm text-text-muted">{cat.description}</p>
      </a>
    ))}
  </div>
</SectionWrapper>
