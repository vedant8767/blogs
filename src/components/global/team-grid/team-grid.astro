---
import SectionWrapper from '../../shared/SectionWrapper.astro';

interface TeamMember {
  name: string;
  role: string;
  photo?: string;
  bio?: string;
  social?: { platform: string; url: string }[];
}

interface Props {
  _name?: string;
  _cms_bind?: string;
  heading?: string;
  subheading?: string;
  members?: TeamMember[];
}

const {
  _cms_bind,
  heading = 'Meet Our Team',
  subheading = 'The people behind the product.',
  members = [
    { name: 'Alex Johnson', role: 'CEO & Founder', photo: '/images/team/member-1.jpg', bio: 'Passionate about building great products.' },
    { name: 'Sam Lee', role: 'CTO', photo: '/images/team/member-2.jpg', bio: 'Engineering leader with 15+ years experience.' },
    { name: 'Jordan Rivera', role: 'Head of Design', photo: '/images/team/member-3.jpg', bio: 'Creating beautiful, functional interfaces.' },
  ],
} = Astro.props;
---

<SectionWrapper>
  <div class="mx-auto max-w-3xl text-center">
    <h2 data-editable="text" data-prop="heading" class="text-3xl font-bold tracking-tight text-secondary sm:text-4xl">{heading}</h2>
    <p data-editable="text" data-prop="subheading" class="mt-4 text-lg text-text-muted">{subheading}</p>
  </div>
  <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {members.map((member, i) => (
      <div class="text-center">
        {member.photo && (
          <img src={member.photo} alt={member.name} data-editable="image" data-prop-src={`members.${i}.photo`} class="mx-auto h-40 w-40 rounded-full object-cover" loading="lazy" />
        )}
        <h3 data-editable="text" data-prop={`members.${i}.name`} class="mt-4 text-lg font-semibold text-secondary">{member.name}</h3>
        <p data-editable="text" data-prop={`members.${i}.role`} class="text-sm text-primary font-medium">{member.role}</p>
        {member.bio && <p data-editable="text" data-prop={`members.${i}.bio`} class="mt-2 text-sm text-text-muted">{member.bio}</p>}
        {member.social && member.social.length > 0 && (
          <div class="mt-3 flex justify-center gap-3">
            {member.social.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-primary text-sm transition-colors">{s.platform}</a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</SectionWrapper>
